<% layout('/layouts/boilerplate') -%>
<body>
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 row-cols-xs-1">
    <% for(let list of allListings){%>
  <div class="card col" style="width: 18rem;">
  <img src="<%=list.image%>" class="card-img-top" alt="...">
  <div class="card-body">
    <p class="card-text"><%=list.title%>
        <br>
      &#8377;<%= list.price.toLocaleString("en-IN") %> / night
    
    </p>
  </div>
  </div>
    <% } %>
</div>

    <h2>All Listings</h2>
    <ul>
        <%    for(let list of allListings){%>

           <a href="/listing/<%=list._id %>"> <li>  <%=list.title%>  </li></a>    
            
            <% } %>

      </ul>
         <form method="get" action="listings/new">

            <button>create</button>
         </form>
      
    
</body>
